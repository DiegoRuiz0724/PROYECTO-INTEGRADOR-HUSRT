<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd" version="3.0">

    <persistence-unit name="proyecto_hurst">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.diegoruiz.entities.Estudiante</class>
        <class>com.diegoruiz.entities.Docente</class>
        <class>com.diegoruiz.entities.Acceso</class>
        <class>com.diegoruiz.entities.Programa</class>
        <class>com.diegoruiz.entities.Universidad</class>
        <class>com.diegoruiz.entities.Practica</class>
        <class>com.diegoruiz.entities.Horario</class>
        <class>com.diegoruiz.entities.ServicioHospitalario</class>
        <class>com.diegoruiz.entities.Documento</class>
        <class>com.diegoruiz.entities.Usuario</class>
        <class>com.diegoruiz.entities.Notificacion</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://127.0.0.1:3306/proyecto_hurst?createDatabaseIfNotExist=true&amp;useSSL=false&amp;allowPublicKeyRetrieval=true"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
