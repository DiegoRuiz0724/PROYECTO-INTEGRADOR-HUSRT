<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.diegoruiz.controllers.RegistroEstudiantesController" spacing="30" style="-fx-background-color: transparent;" stylesheets="@../styles.css">

    <!-- Encabezado con ruta de navegación -->
    <VBox spacing="8">
        <Label text="Gestión Estudiantil  ›  Registro" style="-fx-text-fill: #64748b; -fx-font-size: 13; -fx-font-weight: bold;"/>
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label text="Registro de Estudiantes" styleClass="card-title" style="-fx-font-size: 32;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Nuevo Estudiante" onAction="#onLimpiar" styleClass="btn-primary" style="-fx-background-color: #1e293b;"/>
        </HBox>
    </VBox>

    <!-- Formulario Principal en Tarjeta -->
    <VBox spacing="25" styleClass="card" style="-fx-padding: 40;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="👤 Información del Estudiante" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        </HBox>

        <GridPane hgap="40" vgap="25">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <!-- Fila 1 -->
            <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Nombres" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextField fx:id="txtNombres" promptText="Ej: Juan"/>
            </VBox>

            <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Apellidos" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextField fx:id="txtApellidos" promptText="Ej: Pérez"/>
            </VBox>

            <!-- Fila 2 -->
            <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="Cédula de Ciudadanía" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <HBox spacing="10">
                    <ComboBox fx:id="cbTipoDocumento" prefWidth="150" promptText="Tipo"/>
                    <TextField fx:id="txtDocumento" promptText="Número de identificación" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="Universidad" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <ComboBox fx:id="cbUniversidad" prefWidth="Infinity" promptText="Seleccione una institución"/>
            </VBox>

            <!-- Fila 3 -->
            <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <Label text="Programa Académico" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <ComboBox fx:id="cbPrograma" prefWidth="Infinity" promptText="Seleccione un programa"/>
            </VBox>

            <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <Label text="Tipo de Estudiante" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <ComboBox fx:id="cbTipoEstudiante" prefWidth="Infinity" promptText="Seleccione el tipo"/>
            </VBox>

            <!-- Fila 4 -->
            <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="3">
                <Label text="Semestre" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextField fx:id="txtSemestre" promptText="Ej: 7"/>
            </VBox>

            <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3">
                <Label text="Correo Electrónico Institucional" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextField fx:id="txtEmail" promptText="estudiante@universidad.edu.co"/>
            </VBox>

            <!-- Fila 5: Switches de Estado (Mockup Style) -->
            <HBox spacing="40" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2" style="-fx-padding: 10 0 0 0;">
                <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-padding: 20; -fx-background-color: #f8fafc; -fx-effect: none; -fx-border-color: #e2e8f0;">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Inducción hospitalaria" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                            <DatePicker fx:id="dpFechaInduccion" promptText="mm/dd/yyyy" style="-fx-background-color: transparent; -fx-padding: 0;"/>
                        </VBox>
                        <ToggleButton text="PENDIENTE" style="-fx-background-radius: 20; -fx-font-size: 10; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>

                <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-padding: 20; -fx-background-color: #f8fafc; -fx-effect: none; -fx-border-color: #e2e8f0;">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="ARL vigente" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                            <DatePicker fx:id="dpArlVencimiento" promptText="mm/dd/yyyy" style="-fx-background-color: transparent; -fx-padding: 0;"/>
                        </VBox>
                        <ToggleButton text="VIGENTE" selected="true" style="-fx-background-radius: 20; -fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                    </HBox>
                </VBox>
            </HBox>
        </GridPane>

        <HBox spacing="20" alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
            <Label fx:id="lblMensaje" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
            <Button text="Cancelar" onAction="#onLimpiar" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Button text="🗑 Eliminar" onAction="#onEliminar" styleClass="btn-danger" prefHeight="45" prefWidth="120"/>
            <Button text="💾 Guardar Estudiante" onAction="#onGuardar" prefHeight="45" prefWidth="220" styleClass="btn-primary" style="-fx-background-color: #1e293b;"/>
        </HBox>
    </VBox>

    <!-- Tabla de Estudiantes (Mockup Style) -->
    <VBox spacing="20" VBox.vgrow="ALWAYS" styleClass="card" style="-fx-padding: 30;">
        <HBox alignment="CENTER_LEFT">
            <Label text="Estudiantes registrados este semestre" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="10">
                <Button text="≡" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 5;"/>
                <Button text="📥" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 5;"/>
            </HBox>
        </HBox>

        <TableView fx:id="tablaEstudiantes" VBox.vgrow="ALWAYS" minHeight="600" prefHeight="800">
            <columns>
                <TableColumn fx:id="colNombres" text="NOMBRES" prefWidth="150"/>
                <TableColumn fx:id="colApellidos" text="APELLIDOS" prefWidth="150"/>
                <TableColumn fx:id="colDocumento" text="CÉDULA" prefWidth="120"/>
                <TableColumn fx:id="colSemestre" text="SEM." prefWidth="60" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="colArl" text="ARL" prefWidth="120" style="-fx-alignment: CENTER;"/>
            </columns>
            <placeholder>
                <Label text="No hay estudiantes registrados en el sistema." style="-fx-text-fill: #94a3b8;"/>
            </placeholder>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="lblTotalEstudiantes" text="Cargando estudiantes..." style="-fx-text-fill: #64748b; -fx-font-size: 12;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>
</VBox>