<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<ScrollPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.diegoruiz.controllers.LoginController" fitToWidth="true" fitToHeight="true" style="-fx-background-color: #f1f5f9;" stylesheets="@../styles.css">

    <StackPane style="-fx-background-color: transparent;">
        <VBox alignment="CENTER" spacing="30" maxWidth="450" maxHeight="550" styleClass="card" style="-fx-padding: 50; -fx-background-radius: 20;">

            <VBox alignment="CENTER" spacing="10">
                <Label text="🏥" style="-fx-font-size: 50;"/>
                <Label text="HUSRT" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Sistema de Gestión Hospitalaria" style="-fx-text-fill: #64748b; -fx-font-size: 14;"/>
            </VBox>

            <VBox spacing="20">
                <VBox spacing="8">
                    <Label text="Usuario" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="txtUsername" promptText="Ingrese su usuario" style="-fx-pref-height: 45; -fx-background-radius: 10;"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Contraseña" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <PasswordField fx:id="txtPassword" promptText="••••••••" style="-fx-pref-height: 45; -fx-background-radius: 10;"/>
                </VBox>
            </VBox>

            <VBox spacing="15" alignment="CENTER">
                <Button text="Iniciar Sesión" onAction="#onLogin" maxWidth="Infinity" styleClass="btn-primary" style="-fx-pref-height: 50; -fx-background-color: #1e293b; -fx-background-radius: 10; -fx-font-size: 16;"/>

                <Hyperlink text="¿No tiene una cuenta? Regístrese aquí" onAction="#onGoToRegister" style="-fx-text-fill: #3b82f6; -fx-font-size: 13;"/>

                <Label fx:id="lblError" style="-fx-text-fill: #ef4444; -fx-font-weight: bold;"/>
            </VBox>

            <HBox alignment="CENTER" spacing="10">
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="v1.0" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </StackPane>

</ScrollPane>
