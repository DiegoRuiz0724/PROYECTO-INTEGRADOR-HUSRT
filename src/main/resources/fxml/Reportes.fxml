<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.diegoruiz.controllers.ReportesController"
      spacing="30" style="-fx-background-color: transparent;"
      stylesheets="@../styles.css">

    <!-- Encabezado con Dashboard Action -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label text="📊 Analítica de Datos" style="-fx-text-fill: #3b82f6; -fx-font-size: 12; -fx-font-weight: bold; -fx-text-transform: uppercase;"/>
            <Label text="Panel de Control y Reportes" styleClass="card-title" style="-fx-font-size: 28;"/>
            <Label text="Monitoreo de asistencia, alertas de cumplimiento y estadísticas generales." style="-fx-text-fill: #64748b; -fx-font-size: 14;"/>
        </VBox>
        <Button text="↺ ACTUALIZAR DATOS" onAction="#onActualizarDashboard"
                prefHeight="45" prefWidth="200" styleClass="btn-primary"/>
    </HBox>

    <!-- Dashboard Cards Mejoradas -->
    <HBox spacing="20">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="15" style="-fx-padding: 25; -fx-border-left-color: #3b82f6; -fx-border-left-width: 5;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="👥" style="-fx-font-size: 20;"/>
                <Label text="ESTUDIANTES" style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="lblTotalRegistrados" text="0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Total en el sistema" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;"/>
        </VBox>
        
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="15" style="-fx-padding: 25; -fx-border-left-color: #10b981; -fx-border-left-width: 5;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🏥" style="-fx-font-size: 20;"/>
                <Label text="PRESENCIA" style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="lblDentroAhora" text="0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Activos ahora" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;"/>
        </VBox>
        
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="15" style="-fx-padding: 25; -fx-border-left-color: #f59e0b; -fx-border-left-width: 5;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="⚠" style="-fx-font-size: 20;"/>
                <Label text="ALERTAS ARL" style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="lblAlertasArl" text="0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Próximos vencimientos" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;"/>
        </VBox>
        
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="15" style="-fx-padding: 25; -fx-border-left-color: #ef4444; -fx-border-left-width: 5;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="❌" style="-fx-font-size: 20;"/>
                <Label text="RECHAZOS" style="-fx-text-fill: #64748b; -fx-font-size: 12; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="lblRechazosHoy" text="0" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Accesos denegados hoy" style="-fx-text-fill: #94a3b8; -fx-font-size: 11;"/>
        </VBox>
    </HBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS">
        <!-- Trazabilidad de Horas -->
        <VBox spacing="20" styleClass="card" prefWidth="450" style="-fx-padding: 30;">
            <Label text="🔍 Trazabilidad de Horas" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <VBox spacing="15">
                <VBox spacing="8">
                    <Label text="Documento del Estudiante" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13;"/>
                    <TextField fx:id="txtDocHoras" promptText="Ingrese número de documento..." prefHeight="45"/>
                </VBox>
                <VBox spacing="8">
                    <Label text="Horas Requeridas" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 13;"/>
                    <TextField fx:id="txtHorasReq" promptText="Ej: 40" prefHeight="45"/>
                </VBox>
                <Button text="CONSULTAR REPORTE" onAction="#onConsultarHoras"
                        maxWidth="Infinity" prefHeight="50" styleClass="btn-primary"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox alignment="CENTER" style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 20;">
                <Label fx:id="lblResultadoHoras" text="Esperando consulta..." style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #334155; -fx-text-alignment: center;"/>
            </VBox>
        </VBox>

        <!-- Tabla Alertas ARL -->
        <VBox spacing="15" HBox.hgrow="ALWAYS">
            <Label text="🚩 Alertas de Vencimiento ARL (15 días)" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <TableView fx:id="tablaAlertas" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colAlerNombres"   text="Nombre Estudiante"   prefWidth="250"/>
                    <TableColumn fx:id="colAlerDocumento" text="Documento"           prefWidth="150"/>
                    <TableColumn fx:id="colAlerArl"       text="Fecha Vencimiento"   prefWidth="150" style="-fx-alignment: CENTER;"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </HBox>
</VBox>
