<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.diegoruiz.controllers.NotificacionesController"
      spacing="20" style="-fx-padding: 30; -fx-background-color: transparent;"
      stylesheets="@../styles.css">

    <VBox spacing="8">
        <Label text="🔔 Centro de Alertas" style="-fx-text-fill: #3b82f6; -fx-font-size: 12; -fx-font-weight: bold; -fx-text-transform: uppercase;"/>
        <Label text="Mis Notificaciones" styleClass="card-title" style="-fx-font-size: 28;"/>
        <Label text="Manténgase al tanto de sus registros de ingreso, salida y nuevas asignaciones." style="-fx-text-fill: #64748b;"/>
    </VBox>

    <VBox spacing="15" VBox.vgrow="ALWAYS" styleClass="card" style="-fx-padding: 25;">
        <HBox alignment="CENTER_LEFT">
            <Label text="Historial de Notificaciones" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Marcar todas como leídas" onAction="#onMarcarTodasLeidas" styleClass="btn-primary" style="-fx-background-color: #1e293b;"/>
        </HBox>

        <ListView fx:id="listNotificaciones" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background-insets: 0;"/>
    </VBox>
</VBox>
